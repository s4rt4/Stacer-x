<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2026 Quentin Lienhardt -->
<component type="desktop-application">
    <id>fr.quentium.acters</id>

    <name>Acters</name>
    <summary>Linux System Optimizer &amp; Monitoring</summary>

    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0</project_license>
    <content_rating type="oars-1.1">
        <content_attribute id="money-purchasing">mild</content_attribute>
    </content_rating>
    <developer id="fr.quentium">
        <name>Quentin Lienhardt</name>
    </developer>
    <update_contact>pro@quentium.fr</update_contact>

    <translation type="gettext">stacer</translation>

    <description>
        <p>Acters is an open source system optimizer and application monitor that helps users to manage entire system with different aspects, its an all in one system utility.</p>
    </description>

    <launchable type="desktop-id">fr.quentium.acters.desktop</launchable>

    <icon type="stock">stacer</icon>

    <branding>
        <color type="primary" scheme_preference="light">#025ff9</color>
        <color type="primary" scheme_preference="dark">#075fbb</color>
    </branding>

    <categories>
        <category>Utility</category>
        <category>System</category>
    </categories>

    <keywords>
        <keyword>optimize</keyword>
        <keyword>monitor</keyword>
        <keyword>services</keyword>
    </keywords>

    <url type="homepage">https://stacer.quentium.fr</url>
    <url type="bugtracker">https://github.com/QuentiumYT/Stacer/issues</url>
    <url type="vcs-browser">https://github.com/QuentiumYT/Stacer</url>
    <url type="donation">https://www.paypal.me/QuentiumYT</url>
    <url type="translate">https://crowdin.com/project/stacer</url>

