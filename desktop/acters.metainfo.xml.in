    <provides>
        <binary>stacer</binary>
    </provides>

    <releases>
        <release version="@Stacer_VERSION_MAJOR@.@Stacer_VERSION_MINOR@.@Stacer_VERSION_PATCH@" date="@TODAY_ISO_8601@">
            <description>
                <p>Latest stable release of Acters with performance improvements and bug fixes.</p>
            </description>
        </release>
    </releases>
</component>
